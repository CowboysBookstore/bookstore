# Copy this file to `.env` and fill in real values. Do NOT commit real secrets.

# Django / app settings
DJANGO_SECRET_KEY=replace-me-with-a-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Superuser (optional) - used by entrypoint-dev to create a superuser automatically
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change_me

# Email (optional) - if omitted, Django's console email backend will be used
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Bookstore <no-reply@example.com>
# Django
DJANGO_SECRET_KEY=changeme
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Email (Gmail SMTP — use a Google App Password)
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=Cowboy Bookstore <your-email@gmail.com>

# JWT
JWT_SIGNING_KEY=dev-jwt-signing-key
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7
JWT_ISSUER=cowboy-bookstore
JWT_AUDIENCE=cowboy-users

# Frontend
VITE_API_BASE_URL=http://localhost:8000
